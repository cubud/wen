# Dependencies — none are committed; runtime deps load from the CDN (esm.sh),
# build tools run via npx.
node_modules/

# Build output — regenerated by build.sh and shipped to npm via the package.json
# "files" field, so it never needs to live in git.
dist/
wen-entry.js

# Logs
*.log
npm-debug.log*

# OS / editor cruft
.DS_Store
.vscode/
